{
  "name": "@openclaw/zulip",
  "version": "2026.2.4",
  "description": "OpenClaw Zulip channel plugin",
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "test:e2e": "npx tsx e2e/run.ts"
  },
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@openclaw/e2e": "file:../../packages/openclaw-e2e",
    "typescript": "^5.9.3"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "zulip",
      "label": "Zulip",
      "selectionLabel": "Zulip (plugin)",
      "docsPath": "/channels/zulip",
      "docsLabel": "zulip",
      "blurb": "Zulip streams/topics with reaction-based reply indicators (plugin, installed separately).",
      "order": 70
    },
    "install": {
      "npmSpec": "@openclaw/zulip",
      "localPath": "extensions/zulip",
      "defaultChoice": "npm"
    }
  }
}
